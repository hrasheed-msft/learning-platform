// Prisma Schema for Islamic Studies Learning Platform
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// FAMILY & USER MODELS
// ============================================

model Family {
  id               String         @id @default(uuid())
  name             String
  subscriptionTier String         @default("FREE") // FREE, BASIC, PREMIUM
  subscriptionEnd  DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  users   User[]
  members FamilyMember[]

  activityEvents ActivityEvent[]
  notifications  Notification[]

  @@map("families")
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  role                 String    @default("PARENT") // PARENT, ADMIN
  emailVerified        Boolean   @default(false)
  verificationToken    String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  lastLoginAt          DateTime?
  settings             Json?     @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  selfMemberId String?       @unique
  selfMember   FamilyMember? @relation("UserSelfMember", fields: [selfMemberId], references: [id], onDelete: SetNull)

  notifications Notification[]

  @@index([email])
  @@index([familyId])
  @@map("users")
}

model FamilyMember {
  id             String   @id @default(uuid())
  name           String
  age            Int
  ageCategory    String   // EARLY_CHILD, CHILD, PRE_TEEN, TEEN, ADULT
  isAccountOwner Boolean  @default(false)
  pin            String?  // Optional 4-6 digit PIN for child login
  username       String?  @unique
  passwordHash   String?
  loginEnabled   Boolean  @default(false)

  // Parent PIN gate (account-owner only) — used to re-authenticate when
  // switching from a child learner profile back to the parent view.
  parentPinHash  String?
  pinSetAt       DateTime?
  pinAttempts    Int       @default(0)
  pinLockedUntil DateTime?
  avatarUrl      String?
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  totalPoints    Int      @default(0)
  lastActiveAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  ownerUser User? @relation("UserSelfMember")

  enrollments       CourseEnrollment[]
  achievements      Achievement[]
  quizResults       QuizResult[]
  memorizationItems MemorizationItem[]
  reviewLogs        ReviewLog[]
  flashCardProgress FlashCardProgress[]
  activityEvents    ActivityEvent[]

  // Game relations
  gameSessions            GameSession[]
  gameScores              GameScore[]
  userBadges              UserBadge[]
  userAchievements        UserAchievement[]
  leaderboardEntries      LeaderboardEntry[]
  dailyChallengeAttempts  DailyChallengeAttempt[]
  streakRecord            UserStreakRecord?
  gameParentalSettings    GameParentalSettings?
  gameTimeLogs            GameTimeLog[]

  gender              Gender?
  programEnrollments  ProgramEnrollment[]

  @@index([familyId])
  @@map("family_members")
}

// ============================================
// COURSE & CONTENT MODELS
// ============================================

model Course {
  id             String   @id @default(uuid())
  title          String
  description    String
  category       String   // QURAN, HADITH, FIQH, SEERAH, ARABIC, ISLAMIC_HISTORY
  ageLevels      String[] // Array of: EARLY_CHILD, CHILD, PRE_TEEN, TEEN, ADULT
  thumbnailUrl   String?
  isPublished    Boolean  @default(false)
  slug           String?  @unique // e.g. "maktab-coursebook-3"; nullable until backfilled
  contentVersion Int      @default(1) // increment on breaking content changes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  units       Unit[]
  flashCards  FlashCard[]
  enrollments CourseEnrollment[]
  games       Game[]
  programStages ProgramStage[]

  @@index([category])
  @@index([isPublished])
  @@map("courses")
}

model Unit {
  id          String   @id @default(uuid())
  title       String
  description String?
  content     String?  @db.Text // Rich text / HTML content
  orderIndex  Int
  slug        String?  // e.g. "maktab-3-fiqh"; nullable until backfilled
  includedInPaths LearningPath[]  // Empty = all paths; [AFTER_SCHOOL] = after-school only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  videoResources VideoResource[]
  audioResources AudioResource[]
  arabicTerms    ArabicTerm[]
  questions      Question[]
  flashCards     FlashCard[]
  unitProgress   UnitProgress[]
  quizResults    QuizResult[]
  games          Game[]
  audioCache     AudioCache[]
  videoCache     VideoCache[]

  @@unique([courseId, orderIndex])
  @@unique([courseId, slug]) // composite unique; NULLs are treated as distinct in Postgres
  @@index([courseId])
  @@map("units")
}

model VideoResource {
  id          String   @id @default(uuid())
  title       String
  url         String
  duration    Int?     // Duration in seconds
  thumbnailUrl String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("video_resources")
}

model AudioResource {
  id         String   @id @default(uuid())
  title      String
  url        String
  duration   Int?     // Duration in seconds
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("audio_resources")
}

model ArabicTerm {
  id              String   @id @default(uuid())
  arabicText      String
  transliteration String
  translation     String
  audioUrl        String?
  metadata        Json?
  createdAt       DateTime @default(now())

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("arabic_terms")
}

// ============================================
// ASSESSMENT MODELS
// ============================================

model Question {
  id            String   @id @default(uuid())
  type          String   // MULTIPLE_CHOICE, TRUE_FALSE, MATCHING, FILL_BLANK
  questionText  String   @db.Text
  options       Json?    // Array of options for multiple choice
  correctAnswer String
  explanation   String?  @db.Text
  difficulty    String   @default("MEDIUM") // EASY, MEDIUM, HARD
  aiGenerated   Boolean  @default(false)
  externalId    String?  @unique // e.g. "maktab-3-fiqh-q1"; nullable until backfilled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([type])
  @@map("questions")
}

model QuizResult {
  id        String   @id @default(uuid())
  score     Int      // 0-100 percentage
  passed    Boolean
  timeSpent Int?     // Time spent in seconds
  answers   Json     // Array of { questionId, answer, isCorrect }
  createdAt DateTime @default(now())

  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([unitId])
  @@map("quiz_results")
}

// ============================================
// PROGRAM / MAKTAB ENUMS
// ============================================

enum LearningPath {
  AFTER_SCHOOL
  WEEKEND
}

enum Gender {
  MALE
  FEMALE
}

// ============================================
// FLASH CARD MODELS
// ============================================

enum FlashCardStatus {
  NEW
  LEARNING
  REVIEWING
  MASTERED
}

enum FlashCardDifficulty {
  EASY
  MEDIUM
  HARD
}

model FlashCard {
  id          String               @id @default(uuid())
  front       String               @db.Text // Question/front side
  back        String               @db.Text // Answer/back side
  frontArabic String?              @db.Text // Optional Arabic text for front
  backArabic  String?              @db.Text // Optional Arabic text for back
  category    String               // vocabulary, definition, pattern, example, rule
  tags        String[]             // Array of tags for filtering
  difficulty  FlashCardDifficulty  @default(MEDIUM)
  orderIndex  Int                  // Order within unit
  stageTag    String?              // e.g. "F1", "CB3", "CB6B" — cross-stage view grouping
  subjectTag  String?              // e.g. "DUA", "99NAMES", "FIQH", "HADITH"
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  unitId   String
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progress FlashCardProgress[]

  @@unique([unitId, orderIndex])
  @@index([unitId])
  @@index([courseId])
  @@index([category])
  @@index([difficulty])
  @@map("flashcards")
}

model FlashCardProgress {
  id             String           @id @default(uuid())
  easeFactor     Float            @default(2.5) // SM-2 ease factor (1.3 - 2.5+)
  interval       Int              @default(0)   // Days until next review
  repetitions    Int              @default(0)   // Number of successful reviews
  nextReviewDate DateTime         @default(now()) // When card is due for review
  totalReviews   Int              @default(0)   // Total times reviewed
  correctReviews Int              @default(0)   // Times reviewed correctly (rating 4-5)
  lastRating     Int              @default(0)   // Last rating given (1-5)
  status         FlashCardStatus  @default(NEW) // Current learning status
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  memberId    String
  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  flashCardId String
  flashCard   FlashCard    @relation(fields: [flashCardId], references: [id], onDelete: Cascade)

  @@unique([memberId, flashCardId])
  @@index([memberId])
  @@index([flashCardId])
  @@index([nextReviewDate])
  @@index([status])
  @@map("flashcard_progress")
}

// ============================================
// PROGRESS & ENROLLMENT MODELS
// ============================================

model CourseEnrollment {
  id          String    @id @default(uuid())
  status      String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  progress    Int       @default(0) // 0-100 percentage
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  unitProgress UnitProgress[]

  @@unique([memberId, courseId])
  @@index([memberId])
  @@index([courseId])
  @@map("course_enrollments")
}

model UnitProgress {
  id               String    @id @default(uuid())
  videoCompleted   Boolean   @default(false)
  readingCompleted Boolean   @default(false)
  quizCompleted    Boolean   @default(false)
  quizScore        Int?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  enrollmentId String
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, unitId])
  @@index([enrollmentId])
  @@index([unitId])
  @@map("unit_progress")
}

// ============================================
// SPACED REPETITION (SRS) MODELS
// ============================================

model MemorizationItem {
  id              String    @id @default(uuid())
  type            String    // AYAH, HADITH, DUA, TERM
  front           String    @db.Text // Question/prompt side
  back            String    @db.Text // Answer side
  arabicText      String?   @db.Text
  transliteration String?
  audioUrl        String?
  interval        Int       @default(0) // Days until next review
  easeFactor      Float     @default(2.5) // SM-2 ease factor
  repetitions     Int       @default(0)
  lastReviewedAt  DateTime?
  nextReviewDate  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  sourceUnitId String? // Optional link to source unit

  reviewLogs ReviewLog[]

  @@index([memberId])
  @@index([nextReviewDate])
  @@index([type])
  @@map("memorization_items")
}

model ReviewLog {
  id             String   @id @default(uuid())
  rating         Int      // 1-4 (Again, Hard, Good, Easy)
  intervalBefore Int
  intervalAfter  Int
  createdAt      DateTime @default(now())

  memorizationItemId String
  memorizationItem   MemorizationItem @relation(fields: [memorizationItemId], references: [id], onDelete: Cascade)

  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memorizationItemId])
  @@index([memberId])
  @@index([createdAt])
  @@map("review_logs")
}

// ============================================
// GAMIFICATION MODELS
// ============================================

model Achievement {
  id          String   @id @default(uuid())
  type        String   // STREAK, COURSE_COMPLETE, QUIZ_MASTER, etc.
  name        String
  description String
  iconUrl     String?
  earnedAt    DateTime @default(now())

  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([type])
  @@map("achievements")
}

// ============================================
// ACTIVITY & DASHBOARD MODELS
// ============================================

enum ActivityEventType {
  QUIZ_COMPLETED
  COURSE_STARTED
  COURSE_COMPLETED
  FLASHCARD_REVIEWED
  GAME_PLAYED
  STREAK_REACHED
  BADGE_EARNED
}

enum NotificationType {
  MILESTONE
  ALERT
  WEEKLY_SUMMARY
}

model ActivityEvent {
  id             String            @id @default(uuid())
  eventType      ActivityEventType
  metadata       Json?
  createdAt      DateTime          @default(now())

  familyMemberId String
  familyMember   FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyMemberId])
  @@index([familyId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_events")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// GAME ENGINE MODELS
// ============================================

enum GameType {
  QUICK_RECALL
  PAIR_MATCH
  FLASHCARD_SPRINT
  CLOZE
  WORD_SEARCH
  SEQUENCE_IT
  WORD_SCRAMBLE
  CALLIGRAPHY_TRACE
  FIQH_SCENARIO
}

enum GameCategory {
  COURSE_INTEGRATED
  STANDALONE
}

enum GameDifficulty {
  EASY
  MEDIUM
  HARD
}

enum GameSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIMED_OUT
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum BadgeCategory {
  STREAK
  MASTERY
  EXPLORER
  SPEED
  BUILDER
  SOCIAL
  SPECIAL
}

enum LeaderboardScope {
  FAMILY
  GLOBAL
}

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

model GameTemplate {
  id          String       @id @default(uuid())
  type        GameType     @unique
  category    GameCategory
  name        String
  description String       @db.Text
  iconUrl     String?
  rules       Json         // { minContent, defaultDifficulty, timerDefaults, livesDefaults, scoringRules }
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  games       Game[]

  @@index([category])
  @@index([isActive])
  @@map("game_templates")
}

model Game {
  id          String         @id @default(uuid())
  difficulty  GameDifficulty @default(MEDIUM)
  isActive    Boolean        @default(true)
  presentationConfig  Json?  // Theme/mode metadata (replaces old per-type reskin code)
  courseCompatibility Json?  // { contentType, courseCategory?, minItems } for launcher eligibility
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  templateId  String
  template    GameTemplate   @relation(fields: [templateId], references: [id])

  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)

  sessions    GameSession[]

  @@index([templateId])
  @@index([courseId])
  @@index([unitId])
  @@index([difficulty])
  @@map("games")
}

model GameSession {
  id            String            @id @default(uuid())
  status        GameSessionStatus @default(IN_PROGRESS)
  difficulty    GameDifficulty
  score         Int               @default(0)
  maxScore      Int               @default(0)
  accuracy      Float             @default(0)
  streakBest    Int               @default(0)
  timeSpentMs   Int               @default(0)
  roundsTotal   Int               @default(0)
  roundsCorrect Int               @default(0)
  livesUsed     Int               @default(0)
  metadata      Json?
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  gameId        String
  game          Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  memberId      String
  member        FamilyMember      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  rounds        GameRound[]
  gameScore     GameScore?

  @@index([gameId])
  @@index([memberId])
  @@index([status])
  @@index([startedAt])
  @@index([memberId, gameId])
  @@map("game_sessions")
}

model GameRound {
  id            String   @id @default(uuid())
  roundIndex    Int
  contentType   String   // QUESTION, FLASHCARD, ARABIC_TERM
  contentId     String
  playerAnswer  Json?
  isCorrect     Boolean  @default(false)
  pointsEarned  Int      @default(0)
  timeSpentMs   Int      @default(0)
  srsRating     Int?
  metadata      Json?
  createdAt     DateTime @default(now())

  sessionId     String
  session       GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([contentType, contentId])
  @@map("game_rounds")
}

model GameScore {
  id          String   @id @default(uuid())
  totalScore  Int
  accuracy    Float
  timeSpentMs Int
  xpEarned    Int      @default(0)
  bonuses     Json?
  createdAt   DateTime @default(now())

  sessionId   String   @unique
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  memberId    String
  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
  @@index([memberId, createdAt])
  @@map("game_scores")
}

// ============================================
// BADGE & ACHIEVEMENT MODELS
// ============================================

model BadgeDefinition {
  id          String        @id @default(uuid())
  key         String        @unique
  name        String
  description String
  iconUrl     String?
  category    BadgeCategory
  tier        AchievementTier
  criteria    Json
  xpReward    Int           @default(0)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  userBadges  UserBadge[]

  @@index([category])
  @@index([tier])
  @@map("badge_definitions")
}

model UserBadge {
  id        String   @id @default(uuid())
  earnedAt  DateTime @default(now())

  memberId  String
  member    FamilyMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([memberId, badgeId])
  @@index([memberId])
  @@index([badgeId])
  @@map("user_badges")
}

model UserAchievement {
  id          String   @id @default(uuid())
  type        String
  name        String
  description String
  iconUrl     String?
  xpReward    Int      @default(0)
  metadata    Json?
  earnedAt    DateTime @default(now())

  memberId    String
  member      FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([type])
  @@index([earnedAt])
  @@map("user_achievements")
}

// ============================================
// LEADERBOARD MODELS
// ============================================

model Leaderboard {
  id        String            @id @default(uuid())
  scope     LeaderboardScope
  period    LeaderboardPeriod
  gameType  GameType?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())

  entries   LeaderboardEntry[]

  @@unique([scope, period, gameType, startDate])
  @@index([scope, period])
  @@index([isActive])
  @@map("leaderboards")
}

model LeaderboardEntry {
  id          String   @id @default(uuid())
  rank        Int
  score       Int
  gamesPlayed Int      @default(0)
  accuracy    Float    @default(0)
  updatedAt   DateTime @updatedAt

  leaderboardId String
  leaderboard   Leaderboard  @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  memberId      String
  member        FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, memberId])
  @@index([leaderboardId, rank])
  @@index([memberId])
  @@map("leaderboard_entries")
}

// ============================================
// DAILY CHALLENGE MODELS
// ============================================

model DailyChallenge {
  id          String         @id @default(uuid())
  date        DateTime       @db.Date
  difficulty  GameDifficulty
  contentIds  Json
  seed        Int
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  attempts    DailyChallengeAttempt[]

  @@unique([date, difficulty])
  @@index([date])
  @@map("daily_challenges")
}

model DailyChallengeAttempt {
  id          String   @id @default(uuid())
  score       Int
  accuracy    Float
  timeSpentMs Int
  answers     Json
  completedAt DateTime @default(now())

  challengeId String
  challenge   DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  memberId    String
  member      FamilyMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([challengeId, memberId])
  @@index([challengeId])
  @@index([memberId])
  @@index([completedAt])
  @@map("daily_challenge_attempts")
}

// ============================================
// STREAK MODELS
// ============================================

model UserStreakRecord {
  id               String    @id @default(uuid())
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime  @db.Date
  gracePeriodUsed  Boolean   @default(false)
  freezesRemaining Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memberId         String    @unique
  member           FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  streakAchievements StreakAchievement[]

  @@index([memberId])
  @@index([currentStreak])
  @@map("user_streak_records")
}

model StreakAchievement {
  id          String   @id @default(uuid())
  streakCount Int
  xpReward    Int      @default(0)
  earnedAt    DateTime @default(now())

  streakRecordId String
  streakRecord   UserStreakRecord @relation(fields: [streakRecordId], references: [id], onDelete: Cascade)

  @@unique([streakRecordId, streakCount])
  @@index([streakRecordId])
  @@map("streak_achievements")
}

// ============================================
// PARENTAL CONTROLS MODELS
// ============================================

model GameParentalSettings {
  id                  String         @id @default(cuid())
  dailyLimitMinutes   Int            @default(30)
  weekendLimitMinutes Int            @default(60)
  allowedGameTypes    GameType[]     @default([])
  maxDifficulty       GameDifficulty @default(EASY)
  enforceAfterHour    Int?
  isActive            Boolean        @default(true)
  updatedBy           String
  updatedAt           DateTime       @updatedAt
  createdAt           DateTime       @default(now())

  familyMemberId      String         @unique
  familyMember        FamilyMember   @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@index([familyMemberId])
  @@index([isActive])
  @@map("game_parental_settings")
}

model GameTimeLog {
  id                 String       @id @default(cuid())
  date               String       // YYYY-MM-DD
  minutesPlayed      Int          @default(0)
  sessionsPlayed     Int          @default(0)
  lastSessionEndedAt DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  familyMemberId     String
  familyMember       FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@unique([familyMemberId, date])
  @@index([familyMemberId, date])
  @@index([date])
  @@map("game_time_logs")
}

// ============================================
// TTS / AUDIOBOOK
// ============================================

model AudioCache {
  id           String   @id @default(uuid())
  unitId       String
  language     String   // "ar" | "en"
  blockIndex   Int?     // null = full unit audio
  url          String
  duration     Float?   // seconds
  timestamps   Json?    // [{word, offset, duration}] word-level timing data for karaoke highlighting
  cacheVersion String?  // invalidates stale audio when TTS formatting changes
  createdAt    DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, language, blockIndex])
  @@index([unitId])
  @@map("audio_cache")
}

model VideoCache {
  id        String   @id @default(uuid())
  unitId    String
  language  String   // "ar" | "en"
  url       String
  duration  Float?   // seconds
  status    String   @default("generating") // generating, ready, failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, language])
  @@index([unitId])
  @@map("video_cache")
}

// ============================================
// PROGRAM / MAKTAB MODELS
// ============================================

model Program {
  id            String              @id @default(uuid())
  slug          String              @unique
  name          String
  description   String?             @db.Text
  learningPaths LearningPath[]
  isPublished   Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  stages        ProgramStage[]
  enrollments   ProgramEnrollment[]

  @@map("programs")
}

model ProgramStage {
  id          String   @id @default(uuid())
  stageNumber Int
  name        String
  description String?
  ageMin      Int
  ageMax      Int
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  courses     Course[]
  enrollments ProgramEnrollment[]

  @@unique([programId, stageNumber])
  @@index([programId])
  @@map("program_stages")
}

model ProgramEnrollment {
  id             String       @id @default(uuid())
  path           LearningPath
  status         String       @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  enrolledAt     DateTime     @default(now())
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  familyMemberId String
  familyMember   FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  currentStageId String
  currentStage   ProgramStage @relation(fields: [currentStageId], references: [id])

  @@unique([familyMemberId, programId])
  @@index([familyMemberId])
  @@index([programId])
  @@map("program_enrollments")
}
